+            if (r - header_row) % 2 == 0:
+                for col in range(1, ws.max_column + 1):
+                    ws.cell(row=r, column=col).fill = FILL_ALT
+    _freeze(ws, row=header_row + 1)
+    ws.auto_filter.ref = ws.dimensions
+    _auto_width(ws)
