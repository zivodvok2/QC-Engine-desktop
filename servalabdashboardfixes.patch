+def _style_sheet(ws, header_row: int = 1, banding: bool = True):
+    """Apply navy/white header, alternating banding, freeze pane and auto-filter
+    to a worksheet that pandas has already written via to_excel()."""
+    if ws.max_row < 1 or ws.max_column < 1:
